# Copy to ~/.config/uvoo-hugo-editor/editor.env and edit.
#
# Generate a password with:
#   openssl rand -base64 32

UVOO_HUGO_EDITOR_AUTH_USER=admin
UVOO_HUGO_EDITOR_AUTH_PASSWORD=change-this-long-random-password

# Bind to 127.0.0.1 for local or SSH-tunnel-only access.
# Use 0.0.0.0 only behind TLS, a firewall, or a trusted private network.
UVOO_HUGO_EDITOR_ADDR=127.0.0.1:1314

# Optional. Set this when the editor is served behind a public hostname.
# Example: https://editor.example.com
# UVOO_HUGO_EDITOR_PUBLIC_URL=

# Path to the Hugo site directory.
UVOO_HUGO_EDITOR_SITE=/home/user1/hugo_website_demo

# Hugo preview is proxied through the authenticated editor at /preview/.
# Keep this bound to localhost unless you have a specific reason not to.
UVOO_HUGO_EDITOR_HUGO_ADDR=127.0.0.1:1313

UVOO_HUGO_EDITOR_START_HUGO=true
